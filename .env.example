# Copy to .env.local and fill in values

# Email delivery for contact form and booking inquiries (Resend)
RESEND_API_KEY=
INQUIRY_EMAIL_TO=hello@darkhorsehealinglodge.com

# Stripe (test mode while building)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Map event slugs to Stripe Price IDs (one per event)
# STRIPE_PRICE_EVENT_YOGA_BASICS=price_xxx
# STRIPE_PRICE_EVENT_SOUND_BATH=price_xxx

# Stripe Price IDs for standard rental tiers (once rates are locked)
# STRIPE_PRICE_RENTAL_HOURLY=price_xxx
# STRIPE_PRICE_RENTAL_HALF_DAY=price_xxx
# STRIPE_PRICE_RENTAL_FULL_DAY=price_xxx
